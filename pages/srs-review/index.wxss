.page {
  min-height: 100vh;
  background: #f0f4f8;
  display: flex;
  flex-direction: column;
}

/* ---- 导航 ---- */
.nav {
  display: flex;
  align-items: center;
  padding: 56px 20px 12px;
  position: relative;
}
.nav-back {
  display: flex;
  align-items: center;
  gap: 2px;
  color: #6366f1;
}
.nav-back-icon { font-size: 24px; line-height: 1; }
.nav-back-text { font-size: 15px; }
.debug-btn {
  position: absolute;
  right: 16px;
  font-size: 11px;
  color: #94a3b8;
  background: #f1f5f9;
  padding: 4px 8px;
  border-radius: 6px;
}
.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 14px;
  color: #64748b;
  font-weight: 600;
}

/* ---- 进度条 ---- */
.progress-bar {
  height: 6px;
  background: rgba(99,102,241,0.10);
  margin: 0 24px 20px;
  border-radius: 99px;
  overflow: visible;
  position: relative;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #818cf8 0%, #6366f1 60%, #a78bfa 100%);
  border-radius: 99px;
  transition: width 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
  box-shadow: 0 0 8px rgba(99,102,241,0.45);
}
.progress-fill::after {
  content: '';
  position: absolute;
  right: -1px;
  top: 50%;
  transform: translateY(-50%);
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: #6366f1;
  box-shadow: 0 0 0 3px rgba(99,102,241,0.20), 0 0 10px rgba(99,102,241,0.5);
}

/* ---- 卡片 ---- */
.card-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24px;
  position: relative;
  transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.card {
  width: 100%;
  background: #fff;
  border-radius: 24px;
  padding: 48px 32px 40px;
  box-shadow: 0 8px 32px rgba(15, 23, 42, 0.10);
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 340px;
  position: relative;
}

.card-front {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
}

.card-word {
  font-size: 48px;
  font-weight: 800;
  color: #1e293b;
  letter-spacing: -1px;
  text-align: center;
}

.card-tap-hint {
  font-size: 11px;
  color: #cbd5e1;
  letter-spacing: 2px;
  position: absolute;
  bottom: 28px;
  left: 50%;
  transform: translateX(-50%);
  white-space: nowrap;
}

.card-divider {
  width: 40px;
  height: 2px;
  background: #e2e8f0;
  margin: 20px 0 16px;
  border-radius: 1px;
}

.card-phonetic {
  font-size: 14px;
  color: #94a3b8;
  letter-spacing: 1px;
  margin-bottom: 10px;
  background: #f1f5f9;
  padding: 3px 12px;
  border-radius: 20px;
}

.card-meaning {
  font-size: 26px;
  font-weight: 700;
  color: #334155;
  text-align: center;
  margin-bottom: 16px;
}

.card-category {
  font-size: 12px;
  color: #94a3b8;
}

/* ---- 滑动提示 ---- */
.swipe-hint-left,
.swipe-hint-right {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  padding: 8px 16px;
  border-radius: 10px;
  opacity: 0;
  transition: opacity 0.15s;
  pointer-events: none;
  z-index: 10;
}
.swipe-hint-left {
  left: 28px;
  background: rgba(239, 68, 68, 0.12);
  border: 2px solid #ef4444;
}
.swipe-hint-right {
  right: 28px;
  background: rgba(34, 197, 94, 0.12);
  border: 2px solid #22c55e;
}
.swipe-hint-left.show { opacity: 1; }
.swipe-hint-right.show { opacity: 1; }
.swipe-hint-left .hint-text { color: #ef4444; font-weight: 700; font-size: 13px; }
.swipe-hint-right .hint-text { color: #22c55e; font-weight: 700; font-size: 13px; }

/* ---- 已掌握气泡 ---- */
.mastered-bubble {
  position: absolute;
  top: 20px;
  left: 50%;
  transform: translateX(-50%);
  background: #22c55e;
  color: #fff;
  font-size: 14px;
  font-weight: 700;
  padding: 8px 20px;
  border-radius: 20px;
  opacity: 0;
  transition: opacity 0.2s ease;
  white-space: nowrap;
  z-index: 10;
  pointer-events: none;
}
.mastered-bubble.show { opacity: 1; }

/* ---- 底部操作 ---- */
.bottom-actions {
  padding: 12px 20px 44px;
  opacity: 0;
  transform: translateY(10px);
  transition: all 0.25s ease;
  pointer-events: none;
}
.bottom-actions.show {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}
.action-btns {
  display: flex;
  background: #fff;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(15,23,42,0.10);
}
.btn-forgot,
.btn-remembered {
  flex: 1;
  padding: 18px 0 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}
.btn-forgot:active { background: #fef2f2; }
.btn-remembered:active { background: #f0fdf4; }
.btn-divider {
  width: 1px;
  background: #f1f5f9;
  margin: 14px 0;
}
.btn-emoji { font-size: 22px; }
.btn-label {
  font-size: 15px;
  font-weight: 700;
}
.btn-forgot .btn-label { color: #ef4444; }
.btn-remembered .btn-label { color: #22c55e; }
.btn-sub {
  font-size: 11px;
  color: #94a3b8;
  font-weight: 500;
}

/* ---- 完成页 ---- */
.finish-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 0 40px;
}
.finish-emoji { font-size: 64px; }
.finish-title { font-size: 24px; font-weight: 800; color: #1e293b; }
.finish-sub { font-size: 14px; color: #64748b; text-align: center; }
.finish-btn {
  margin-top: 24px;
  background: #6366f1;
  color: #fff;
  font-size: 16px;
  font-weight: 700;
  padding: 14px 48px;
  border-radius: 16px;
}
.finish-btn:active { background: #4f46e5; }
